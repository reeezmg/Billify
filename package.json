{
  "name": "billify",
  "private": true,
  "version": "0.1.8",
  "type": "module",
  "scripts": {
    "dev": "node scripts/without-electron-run-as-node.cjs electron-vite dev",
    "dev:chrome": "node scripts/dev-chrome.mjs",
    "build": "node scripts/without-electron-run-as-node.cjs electron-vite build && node scripts/without-electron-run-as-node.cjs electron-builder",
    "preview": "electron-vite preview",
    "test": "vitest run"
  },
  "main": "out/main/index.js",
  "build": {
    "appId": "com.billify.desktop",
    "productName": "Billify",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "electron/db/migrations/**",
      "resources/**"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "publish": [
      {
        "provider": "github",
        "owner": "reeezmg",
        "repo": "Billify"
      }
    ]
  },
  "dependencies": {
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.3",
    "dayjs": "^1.11.13",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.6.2",
    "form-data": "^4.0.2",
    "pdfkit": "^0.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.56.4",
    "react-router-dom": "^6.30.1",
    "sql.js": "^1.14.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^18.3.21",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.21",
    "electron": "^35.7.4",
    "electron-builder": "^26.0.12",
    "electron-vite": "^2.3.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^5.4.19",
    "vitest": "^3.1.3"
  }
}
